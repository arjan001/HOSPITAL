# Shaniid RX — environment variable reference
# Copy relevant sections to .env and fill in real values.
# Never commit a .env file with real secrets to version control.

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=shaniidrx
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=shaniidrx
POSTGRES_PORT=5432
ADMINER_PORT=8081
DATABASE_URL=postgres://shaniidrx:change-me-strong-password@localhost:5432/shaniidrx

# ─── Auth (Clerk) ─────────────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_live_...
CLERK_PUBLISHABLE_KEY=pk_live_...
VITE_CLERK_PUBLISHABLE_KEY=pk_live_...
# Optional — satellite / custom domain only (leave unset for standard Clerk)
# CLERK_PROXY_URL=https://yourdomain.com/api/__clerk
# VITE_CLERK_PROXY_URL=https://yourdomain.com/api/__clerk
SESSION_SECRET=a-long-random-string

# ─── Payments (Paystack) ──────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_live_...
VITE_PAYSTACK_PUBLIC_KEY=pk_live_...

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@shaniidrx.com

# ─── Video / Calls (Daily.co) ────────────────────────────────────────────────
DAILY_API_KEY=...

# ─── Prescription OCR (order capture) ─────────────────────────────────────────
# Vision extraction for uploaded Rx scans. Without a key, PDF text + Tesseract OCR
# are used with heuristic medication parsing.
OPENAI_API_KEY=
OPENAI_RX_MODEL=gpt-4o-mini
# Set to 1 to disable automated read/extraction entirely
RX_EXTRACTION_DISABLED=

# ─── WhatsApp (dual channel) ─────────────────────────────────────────────────
# Confirmations: Twilio transactional (order/Rx/payment/refill)
WHATSAPP_CONFIRMATIONS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Prescription intake bot: Meta Cloud webhook
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_API_VERSION=v21.0

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8080
