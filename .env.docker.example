# Shaniid RX — docker-compose env template
# Copy to .env.docker and replace the placeholder values.

POSTGRES_USER=shaniidrx
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=shaniidrx
POSTGRES_PORT=5432

# Adminer (web UI for the DB). Optional; remove the adminer service from
# docker-compose.yml if you don't want it.
ADMINER_PORT=8081

# The connection string the app should use (mirrors the values above).
DATABASE_URL=postgres://shaniidrx:change-me-strong-password@localhost:5432/shaniidrx
